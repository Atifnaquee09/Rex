# --- Auth (pick ONE, leave the other blank) ---
# OPTION A (free with a Claude Max/Pro subscription): run `claude setup-token`, paste here
CLAUDE_CODE_OAUTH_TOKEN=
# OPTION B (paid API credits from console.anthropic.com)
ANTHROPIC_API_KEY=

# --- Slack (Socket Mode — no public URL needed) ---
# Bot token from OAuth & Permissions (starts xoxb-)
SLACK_BOT_TOKEN=xoxb-...
# App-level token with connections:write (starts xapp-) — enables Socket Mode
SLACK_APP_TOKEN=xapp-...
# Signing secret from Basic Information
SLACK_SIGNING_SECRET=...

# --- Rex worker ---
# Absolute path to the ONE codebase Rex works on
REX_WORKSPACE=/absolute/path/to/your/codebase
# Model alias: opus | sonnet | haiku
REX_MODEL=opus
# Max agentic turns per ticket (safety cap)
REX_MAX_TURNS=40

# --- Dashboard ---
PORT=4000
